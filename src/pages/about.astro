---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="About - Marius Wagner">
  <div class="pt-24 pb-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl font-bold text-gray-900 mb-8">About Me</h1>

      <div class="max-w-none">
        <p class="text-xl text-gray-600 mb-6">
          Hi! I'm Marius Wagner, a passionate developer and student based in Munich, Germany. I love building beautiful, functional web applications and exploring the intersection of software development and machine learning.
        </p>

        <h2 class="text-3xl font-bold text-gray-900 mt-12 mb-6">Background</h2>
        <p class="text-gray-600 mb-6">
          I'm currently studying at the Technical University of Munich (TUM), where I focus on computer science, with a particular interest in web technologies and AI/ML applications. My journey in tech started with a passion for solving problems and creating solutions that make a difference.
        </p>

        <h2 class="text-3xl font-bold text-gray-900 mt-12 mb-6">What I Do</h2>
        <div class="space-y-4 mb-6">
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Web Development</h3>
            <p class="text-gray-600">I build modern, responsive web applications using React, TypeScript, Astro, and Tailwind CSS. I focus on creating intuitive user experiences with clean, maintainable code.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Machine Learning</h3>
            <p class="text-gray-600">I explore AI and ML with PyTorch, NumPy, and Pandas, working on projects that leverage data analysis and deep learning techniques.</p>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Open Source</h3>
            <p class="text-gray-600">I actively contribute to open-source projects, believing in the power of community-driven development and knowledge sharing.</p>
          </div>
        </div>

        <h2 class="text-3xl font-bold text-gray-900 mt-12 mb-6">Tech Stack</h2>
        <div class="grid md:grid-cols-2 gap-6 mb-6">
          <div>
            <h3 class="text-lg font-bold text-gray-900 mb-3">Frontend</h3>
            <ul class="space-y-2 text-gray-600">
              <li>• React & Next.js</li>
              <li>• TypeScript</li>
              <li>• Tailwind CSS</li>
              <li>• Astro</li>
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-bold text-gray-900 mb-3">Backend & Tools</h3>
            <ul class="space-y-2 text-gray-600">
              <li>• Python & Java</li>
              <li>• Git & GitHub</li>
              <li>• Docker</li>
              <li>• Linux</li>
            </ul>
          </div>
        </div>

        <h2 class="text-3xl font-bold text-gray-900 mt-12 mb-6">Let's Connect</h2>
        <p class="text-gray-600 mb-6">
          I'm always open to new opportunities, collaborations, and conversations about tech, web development, and innovation. Feel free to reach out!
        </p>

        <div class="flex gap-4 flex-wrap">
          <a
            href="mailto:marius-wagner-contact@mailbox.org"
            class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition font-medium"
          >
            Send an Email
          </a>
          <a
            href="https://github.com/Marius1501"
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-3 border-2 border-blue-600 text-blue-600 rounded-lg hover:bg-blue-50 transition font-medium"
          >
            GitHub Profile
          </a>
          <a
            href="https://www.linkedin.com/in/marius-wagner-b39524210/"
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-3 border-2 border-blue-600 text-blue-600 rounded-lg hover:bg-blue-50 transition font-medium"
          >
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
